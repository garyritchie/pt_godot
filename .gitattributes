# Disable png jpg when used for documentation (Gitea/markdown rendering) -- _order is important._
DOC/*.png -filter=lfs -diff=lfs -merge=lfs
DOC/*.jpg -filter=lfs -diff=lfs -merge=lfs
DOC/IMAGE/*.png -filter=lfs -diff=lfs -merge=lfs
DOC/IMAGE/*.jpg -filter=lfs -diff=lfs -merge=lfs
DAILIES/**/*.png -filter=lfs -diff=lfs -merge=lfs
DAILIES/**/*.jpg -filter=lfs -diff=lfs -merge=lfs
